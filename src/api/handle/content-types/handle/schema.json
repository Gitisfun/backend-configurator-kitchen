{
  "kind": "collectionType",
  "collectionName": "handles",
  "info": {
    "singularName": "handle",
    "pluralName": "handles",
    "displayName": "Handle"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "color": {
      "type": "string"
    },
    "price": {
      "type": "decimal"
    },
    "hasHold": {
      "type": "boolean",
      "default": false
    },
    "position": {
      "type": "integer",
      "default": 0
    },
    "code": {
      "type": "string"
    },
    "handlePostions": {
      "type": "string"
    },
    "height": {
      "type": "string"
    },
    "surchargeDisplay": {
      "type": "string"
    },
    "catalogType": {
      "type": "string"
    },
    "catalogSubtype": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "handlePositions": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::handle-position.handle-position",
      "mappedBy": "handles"
    }
  }
}
